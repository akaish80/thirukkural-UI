{
  "name": "thirukurral",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@loadable/component": "^5.16.4",
    "@reduxjs/toolkit": "^2.8.2",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "axios": "^1.7.3",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "eslint-import-resolver-webpack": "^0.13.8",
    "express": "^5.1.0",
    "fuse.js": "^6.6.2",
    "node-fetch": "^2.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router": "^6.26.0",
    "react-router-dom": "^6.26.0",
    "react-scripts": "5.0.1",
    "redux": "^5.0.1",
    "reselect": "^5.1.1",
    "styled-components": "^6.1.12",
    "web-vitals": "^4.2.3"
  },
  "scripts": {
    "start": "set GENERATE_SOURCEMAP=true && concurrently \"node server.js\" \"react-scripts start\"",
    "start:prod": "node server.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src",
    "lint:fix": "yarn run lint --fix",
    "browsers": "browserslist",
    "deploy": "react-scripts build && aws s3 rm s3://mythirukurral.com/ --recursive && aws s3 cp ./build s3://mythirukurral.com/ --recursive --acl public-read",
    "deploy:server": "echo 'NOTE: deploy:server is a placeholder. To run frontend+api on mythirukurral.com you must deploy the project to a Node-capable host (EC2, Elastic Beanstalk, DigitalOcean, Heroku, etc.).' && exit 0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/loadable__component": "^5.13.10",
    "@types/node": "^24.10.1",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "browserslist": "^4.23.3",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "sass": "^1.77.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "defaults"
  ]
}
